# =============================================================================
# JANICE Returns & Exchanges App — Omgevingsvariabelen (voorbeeld)
# =============================================================================
#
# Kopieer dit bestand naar .env en vul alle waarden in vóór het opstarten.
# Deel NOOIT het .env-bestand — het staat in .gitignore.
#
# Aanvraaglocaties staan per variabele vermeld.
# =============================================================================

# --- Node.js runtime --------------------------------------------------------
# Omgeving: development | test | production
NODE_ENV=development

# --- Applicatie-URL ----------------------------------------------------------
# Publieke URL van de Returns-app op Coolify/Hetzner.
# Voorbeeld productie: https://returns.janice.com
# Voorbeeld development: http://localhost:3000
APP_URL=__SET_THIS__

# --- Shopify -----------------------------------------------------------------
# Shopify winkel-domein — altijd in het formaat xxx.myshopify.com
# Nooit het aangepaste domein (janiceofficial.com) gebruiken
SHOPIFY_SHOP_DOMAIN=u17s8e-sc.myshopify.com

# =============================================================================
# SHOPIFY AUTHENTICATIE — kies één van de twee methoden hieronder
# =============================================================================
#
# Methode 1 (AANBEVOLEN): OAuth2 automatische token-vernieuwing
# -------------------------------------------------------------------
# Gebruik SHOPIFY_API_KEY + SHOPIFY_API_SECRET voor automatische vernieuwing.
# Tokens worden elke 24u vernieuwd via OAuth2 client_credentials grant.
# Gecacht in Redis — gedeeld over web + worker processen.
# Vernieuwing elke 4u (6x per tokenleven) voor hoge betrouwbaarheid.
#
# Shopify Admin → Apps → Jouw Custom App → App credentials:
#   - API key (= client_id)  → SHOPIFY_API_KEY
#   - Client secret          → SHOPIFY_API_SECRET (ook vereist voor HMAC)
#
SHOPIFY_API_KEY=__SET_THIS__

# Shopify Custom App client secret — twee doeleinden:
#   1. OAuth2 client_credentials grant (token-vernieuwing)
#   2. App Proxy HMAC-verificatie (verplicht)
# Te vinden in: Shopify Admin → Apps → Jouw app → App credentials → Client secret
# NOOIT de waarde in code opnemen of vastleggen in versiebeheer
SHOPIFY_API_SECRET=__SET_THIS__

# Methode 2 (VEROUDERD): Statisch Admin API access token
# -------------------------------------------------------------------
# VEROUDERD — tokens verlopen na 24u en vereisen handmatige vernieuwing.
# Gebruik alleen als SHOPIFY_API_KEY + SHOPIFY_API_SECRET niet beschikbaar zijn.
# Als zowel API_KEY/SECRET als ADMIN_TOKEN zijn ingesteld: API_KEY/SECRET heeft voorrang.
#
# Bestaande Coolify-deployments met alleen SHOPIFY_ADMIN_TOKEN blijven werken
# zonder aanpassing. Voeg SHOPIFY_API_KEY toe voor de upgrade naar auto-refresh.
#
# Aanmaken via: Shopify Admin → Apps → Jouw Custom App → App credentials
# Formaat: shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# SHOPIFY_ADMIN_TOKEN=shpat___SET_THIS_OR_REMOVE_IF_USING_API_KEY__

# --- JWT ---------------------------------------------------------------------
# Geheim voor het ondertekenen van gast-JWTs (15 minuten geldig).
# Gebruik een willekeurige 64-tekens string in productie.
# Genereer met: openssl rand -hex 32
# NOOIT dezelfde waarde als SHOPIFY_API_SECRET gebruiken!
JWT_SECRET=__SET_THIS_MIN_32_CHARS__

# --- Database ----------------------------------------------------------------
# PostgreSQL-verbindingsstring — Postgres 15 op Coolify/Hetzner
# Formaat: postgresql://gebruiker:wachtwoord@host:5432/databasenaam
DATABASE_URL=postgresql://__SET_THIS__:__SET_THIS__@localhost:5432/janice_returns

# Test-database voor integratietests (optioneel — standaard pg-mem in gebruik)
# DATABASE_URL_TEST=postgresql://__SET_THIS__:__SET_THIS__@localhost:5432/janice_returns_test

# --- Redis -------------------------------------------------------------------
# Redis-verbindingsstring voor BullMQ (achtergrondtaken + webhook-retries)
# Redis 7 op Coolify/Hetzner
REDIS_URL=redis://localhost:6379

# --- DHL Parcel NL Returns API -----------------------------------------------
# Aanvragen via DHL Parcel NL Business Portal (Mijn DHL voor Zakelijk)
# Documentatie: https://api-gw.dhlparcel.nl/docs/

# API-sleutel voor authenticatie bij DHL Parcel NL API (legacy, vervangen door onderstaande)
DHL_API_KEY=__SET_THIS__

# DHL-gebruikers-ID (klantnummer in DHL-portaal)
DHL_USER_ID=__SET_THIS__

# DHL-retouraccount-ID — het account waarop retourzendingen worden geboekt
DHL_RETURN_ACCOUNT_ID=__SET_THIS__

# Gedeeld geheim voor DHL-trackingwebhooks — stel in bij DHL webhook-configuratie
DHL_WEBHOOK_SECRET=__SET_THIS__

# --- DHL Parcel NL Returns API (PR #4 — Track A integratie) ------------------
# Variabelen voor de DHL Parcel NL Returns API client (app/lib/dhl/parcel-nl.server.ts)
# Zet in zodra DHL-credentials beschikbaar zijn (Sean ontvangt via DHL Business Portal)

# Basis-URL van DHL Parcel NL API (standaard: https://api-gw.dhlparcel.nl)
DHL_PARCEL_NL_API_URL=https://api-gw.dhlparcel.nl

# DHL gebruikers-ID voor OAuth2 authenticatie
DHL_PARCEL_NL_USER_ID=__SET_THIS__

# DHL API-sleutel voor OAuth2 authenticatie
DHL_PARCEL_NL_KEY=__SET_THIS__

# DHL account-ID voor retourlabels
DHL_PARCEL_NL_ACCOUNT_ID=__SET_THIS__

# --- BullMQ Workers ----------------------------------------------------------
# Zet op 'true' om BullMQ-workers in hetzelfde proces te starten (V1 / development).
# In productie (sprint 2): workers draaien in een aparte container.
RUN_WORKERS=false

# --- GoedGepickt -------------------------------------------------------------
# Gedeeld HMAC-geheim voor GoedGepickt return.received-webhooks
# Instellen in GoedGepickt-portaal onder Instellingen → Webhooks
# Webhook-URL: https://returns.janice.com/webhooks/goedgepickt
GOEDGEPICKT_WEBHOOK_SECRET=__SET_THIS__

# --- Klaviyo -----------------------------------------------------------------
# Private API-sleutel — aanmaken via Klaviyo Dashboard
# (Klaviyo → Settings → API Keys → Maak nieuwe private key)
# Vereiste rechten: Profiles (schrijven), Events (schrijven)
KLAVIYO_PRIVATE_API_KEY=pk___SET_THIS__

# Alias voor Klaviyo private key (gebruikt door PR #4 events client)
KLAVIYO_PRIVATE_KEY=pk___SET_THIS__

# --- Sentry ------------------------------------------------------------------
# DSN voor de JANICE Returns & Exchanges app — aanmaken via sentry.io
# (Sentry → Projects → Nieuw project → Node.js → DSN kopiëren)
SENTRY_DSN_RETURNS_APP=https://__SET_THIS__@o0.ingest.sentry.io/0
